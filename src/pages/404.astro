---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { buildPageMeta } from '../utils/seo';

const pageMeta = buildPageMeta({
  title: '页面未找到',
  description: '您访问的页面不存在',
  noIndex: true,
});
---

<BaseLayout meta={pageMeta}>
  <section class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="text-8xl font-bold text-accent mb-4">404</div>
      <h1 class="text-2xl font-bold mb-4">页面未找到</h1>
      <p class="text-text-muted mb-8">您访问的页面不存在或已被移除</p>
      <div class="flex items-center justify-center gap-4">
        <Button href="/" variant="primary">返回首页</Button>
        <Button href="/contact" variant="outline">联系我们</Button>
      </div>
    </div>
  </section>
</BaseLayout>
