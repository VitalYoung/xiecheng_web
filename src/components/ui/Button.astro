---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: extraClass = '' } = Astro.props;

const baseClass = 'inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-300 cursor-pointer no-underline';

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variantClasses = {
  primary: 'bg-accent text-bg-primary hover:bg-accent-hover shadow-lg shadow-accent-subtle hover:shadow-xl',
  outline: 'border border-steel/40 text-text-primary hover:border-accent hover:text-accent',
};
---

<a
  href={href}
  class={`${baseClass} ${sizeClasses[size]} ${variantClasses[variant]} ${extraClass}`}
>
  <slot />
</a>
