---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-16">
  <div class="flex items-center justify-center gap-4 mb-4">
    <div class="h-px flex-1 max-w-12 bg-gradient-to-r from-transparent to-accent/40"></div>
    <h2 class="text-3xl md:text-4xl font-bold">{title}</h2>
    <div class="h-px flex-1 max-w-12 bg-gradient-to-l from-transparent to-accent/40"></div>
  </div>
  {subtitle && (
    <p class="text-text-muted text-lg max-w-2xl mx-auto">{subtitle}</p>
  )}
</div>
