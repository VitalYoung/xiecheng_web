---
interface Props {
  title: string;
  summary: string;
  icon?: string;
  href: string;
}

const { title, summary, icon = 'cut', href } = Astro.props;

const icons: Record<string, string> = {
  cut: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  bend: 'M4 6h16M4 12h16M4 18h16M8 6v12M12 6v12M16 6v12',
  tube: 'M12 2a7 7 0 0 0-7 7v6a7 7 0 0 0 14 0V9a7 7 0 0 0-7-7zm0 4a3 3 0 0 1 3 3H9a3 3 0 0 1 3-3z',
  weld: 'M12 2l3 7h6l-5 4 2 7-6-4-6 4 2-7-5-4h6z',
};
---

<a href={href} class="card block group no-underline">
  <div class="w-12 h-12 rounded-lg bg-accent-subtle flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[icon]} />
    </svg>
  </div>
  <h3 class="text-lg font-semibold mb-2 text-text-primary group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed">{summary}</p>
</a>
